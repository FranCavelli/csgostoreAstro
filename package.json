{
  "name": "sixstore",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "CS2 skin store — genera un sitio estático con inventario y precios del perfil de Steam.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "update": "node scripts/update-inventory.mjs --once",
    "updater": "node scripts/update-inventory.mjs --watch",
    "update:build": "npm run update && npm run build"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.5.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "typescript": "^5.7.3"
  }
}
