# --- Perfil Steam ---
STEAM_ID=76561198262015349
STEAM_VANITY=sixbulletss
STEAM_APP_ID=730

# --- CSGOEmpire (fuente de precios) ---
# API key desde https://csgoempire.com/trading/apikey
CSGOEMPIRE_API_KEY=
# Divisor para convertir market_value (coin-cents) a USD.
# 100 = valor validado comparando varios items contra precios reales de CSGOEmpire.
# (market_value viene en "coin-cents" y 1 coin ≈ 1 USD en su sitio)
EMPIRE_USD_DIVISOR=100

# --- Multiplicadores ---
# Markup sobre el precio de CSGOEmpire. 1 = sin markup.
MARKET_MULTIPLIER=1
# Markup sobre el precio de Steam (fallback para items no listados en CSGOEmpire).
STEAM_MULTIPLIER=1

# --- Moneda ---
CURRENCY_ISO=USD
STEAM_CURRENCY=1
# Tasa USD→CURRENCY_ISO. Solo aplica si CURRENCY_ISO != USD.
# EXCHANGE_RATE_USD=1200

# --- Updater ---
UPDATE_INTERVAL_MINUTES=30
# Cuánto tiempo se cachea el precio de Steam entre corridas (evita re-pedir
# siempre y respeta rate-limit de Steam).
STEAM_FALLBACK_TTL_MINUTES=720

# --- Redes ---
# Cambiá en el futuro al link real de tu server.
DISCORD_URL=https://discord.gg/Dx3cGVvqnq
KICK_USERNAME=sixbulletss
