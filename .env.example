# --- Perfil Steam ---
STEAM_ID=76561198262015349
STEAM_VANITY=sixbulletss
STEAM_APP_ID=730

# --- Multiplicadores ---
# Para items con precio de mercado (trader prices): ya son precios reales, default 1.
MARKET_MULTIPLIER=1
# Fallback: items que no están listados en el mercado → precio de Steam × este factor.
# Steam infla listings por sus fees, ×2 compensa.
STEAM_MULTIPLIER=2

# --- Moneda ---
CURRENCY_ISO=ARS
STEAM_CURRENCY=34
# Tasa USD→CURRENCY_ISO. Vacío = se pide live a open.er-api.com.
# EXCHANGE_RATE_USD=1200

# --- Updater ---
UPDATE_INTERVAL_MINUTES=30
# Los fallback de Steam se cachean este tiempo para no martillarlo cada loop.
STEAM_FALLBACK_TTL_MINUTES=720
