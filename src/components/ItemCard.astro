---
import type { StoreItem } from "~/lib/types";
import { formatMoney, steamIconUrl, itemDetailUrl } from "~/lib/store";

interface Props {
  item: StoreItem;
}
const { item } = Astro.props;
const img = steamIconUrl(item.iconUrl, 256);
const rarityColor = item.rarityColor || "#d4a84c";
const detailUrl = itemDetailUrl(item.marketHashName);
const slug = encodeURIComponent(item.marketHashName);
const subtitle = [item.quality, item.exterior].filter(Boolean).join(" · ");
---

<a
  href={detailUrl}
  class="item-card card flex flex-col overflow-hidden"
  style={`--rarity: ${rarityColor}`}
  title={item.name}
>
  <div class="aspect-[5/4] relative">
    {img ? (
      <img
        src={img}
        alt={item.name}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-contain p-3"
        transition:name={`img-${slug}`}
      />
    ) : null}
    {item.count > 1 ? (
      <span class="absolute top-2 right-2 text-[11px] text-muted px-1.5 py-0.5 rounded bg-black/40 backdrop-blur">
        ×{item.count}
      </span>
    ) : null}
  </div>

  <div class="px-3.5 pb-3 pt-2.5 flex flex-col gap-0.5">
    <span
      class="text-[13px] text-text truncate"
      transition:name={`name-${slug}`}
    >{item.name}</span>
    {subtitle ? (
      <span class="text-[11px] text-muted truncate">{subtitle}</span>
    ) : null}
    <span
      class="text-sm font-semibold text-accent tabular-nums mt-1"
      transition:name={`price-${slug}`}
    >
      {formatMoney(item.storePrice)}
    </span>
  </div>
</a>
