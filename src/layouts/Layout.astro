---
import "~/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { config } from "~/lib/config";
import { loadProfile, homeUrl } from "~/lib/store";

interface Props {
  title?: string;
  description?: string;
}
const { title = "Sixbulletss Store", description = "Tienda de skins CS2" } = Astro.props;
const profileUrl = `https://steamcommunity.com/id/${config.steamVanity}`;

const profile = await loadProfile();
const favicon = profile.avatarIcon || profile.avatarFull || "/favicon.svg";
const kickUrl = `https://kick.com/${config.kickUsername}`;
const discordEnabled = !!config.discordUrl && config.discordUrl !== "#";
const avatar = `${import.meta.env.BASE_URL}lion.webp`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={favicon} />
    <link rel="preconnect" href="https://community.cloudflare.steamstatic.com" crossorigin />
    <link rel="preconnect" href="https://avatars.fastly.steamstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Unbounded:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <header class="sticky top-0 z-30">
      <div class="glass-soft border-b border-white/5">
        <div class="max-w-6xl mx-auto px-5 py-3 flex items-center gap-4">
          <a href={homeUrl()} class="flex items-center gap-3">
            {profile.avatarIcon ? (
              <img src={avatar} alt={profile.avatarIcon} class="w-7 h-7 rounded" />
            ) : 
              <img src={avatar} alt="Sixbulletss" class="w-7 h-7 rounded" />
            }
            <span class="text-sm font-medium tracking-wide">Sixbulletss Store</span>
          </a>
          <nav class="ml-auto flex items-center gap-4 text-sm">
            <a
              class="text-muted hover:text-accent hidden sm:inline"
              href={profileUrl}
              target="_blank"
              rel="noopener"
            >Steam ↗</a>
            {discordEnabled ? (
              <a
                class="text-muted hover:text-accent"
                href={config.discordUrl}
                target="_blank"
                rel="noopener"
              >Discord ↗</a>
            ) : (
              <span
                class="text-muted/40 cursor-not-allowed"
                title="Próximamente"
              >Discord</span>
            )}
            <a
              id="kick-link"
              class="text-muted hover:text-accent inline-flex items-center gap-2"
              href={kickUrl}
              target="_blank"
              rel="noopener"
            >
              <span id="dotLive" class= "hidden w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
              <span>Kick ↗</span>
              <span
                id="kick-live"
                class="hidden inline-flex items-center gap-1.5 rounded-full border border-green-500/40 bg-green-500/15 px-2.5 py-0.5 text-[10px] text-green-400 uppercase tracking-[0.2em]"
                aria-hidden="true"
              >
                En vivo
              </span>
            </a>
          </nav>
        </div>
      </div>
    </header>
    <main class="max-w-6xl mx-auto px-5 py-8">
      <slot />
    </main>
    <script is:inline define:vars={{ KICK_USERNAME: config.kickUsername }}>
      // Poll Kick channel status y actualiza el puntito en el header.
      // Si CORS/API bloquea, queda en gris (falla silenciosa).
      async function checkKickLive() {
        try {
          const r = await fetch(`https://kick.com/api/v2/channels/${KICK_USERNAME}`, {
            credentials: "omit",
            cache: "no-store",
          });
          if (!r.ok) return;
          const data = await r.json();
          const live = !!(data && data.livestream);
          const pill = document.getElementById("kick-live");
          const dot = document.getElementById("dotLive");
          if (!pill) return;
          pill.classList.toggle("hidden", !live);
          dot.classList.toggle("hidden", !live);
        } catch {}
      }
      checkKickLive();
      // Refrescar cada 90s por si se pone/saca en vivo mientras alguien mira.
      setInterval(checkKickLive, 90000);
      document.addEventListener("astro:page-load", checkKickLive);
    </script>

    <footer class="max-w-6xl mx-auto px-5 py-10 text-xs text-muted">
      <div class="border-t border-white/5 pt-4 flex items-center justify-between">
        <span>steamcommunity.com/id/{config.steamVanity}</span>
        <span>Precios orientativos · sujetos a variación del mercado</span>
      </div>
    </footer>
  </body>
</html>
